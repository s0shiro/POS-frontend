{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pos-backend-m81a.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://pos-backend-m81a.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets).*)",
      "destination": "/index.html"
    }
  ]
}
