{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://restaurant-pos-backend-4941234254c5.herokuapp.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://restaurant-pos-backend-4941234254c5.herokuapp.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets).*)",
      "destination": "/index.html"
    }
  ]
}
